{
  "name": "quick-cut",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "description": "快速剪辑：跨平台视频时间片段裁切与合并工具",
  "main": "electron/main.cjs",
  "author": "maopai",
  "license": "MIT",
  "homepage": "https://github.com/maopai/quick-cut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maopai/quick-cut.git"
  },
  "bugs": {
    "url": "https://github.com/maopai/quick-cut/issues"
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "video-editor",
    "react",
    "desktop"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder",
    "build:dir": "npm run build:web && electron-builder --dir",
    "build:win:x64": "npm run build:web && electron-builder --win --x64",
    "test": "node --test src/*.test.js electron/*.test.cjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@fontsource-variable/inter": "^5.2.8",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "png-to-ico": "^3.0.2",
    "vite": "^8.1.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.quickcut.desktop",
    "productName": "快速剪辑",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ],
    "mac": {
      "artifactName": "Quick-Cut-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.video",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Quick-Cut-${version}-Windows-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "Quick-Cut-${version}-Windows-${arch}-Portable.${ext}"
    }
  }
}
